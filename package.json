{
  "name": "pcsc-monorepo",
  "private": true,
  "type": "module",
  "imports": {
    "#pcsc": {
      "source": "./packages/pcsc/src/index.ts",
      "default": "./packages/pcsc/dist/index.js"
    },
    "#pcsc-sys": {
      "source": "./packages/pcsc-sys/src/index.ts",
      "default": "./packages/pcsc-sys/dist/index.js"
    }
  },
  "description": "Node.js PC/SC smart card bindings — monorepo",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "smoke": "pnpm --filter examples smoke",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
