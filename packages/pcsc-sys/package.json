{
  "name": "@remirth/pcsc-sys",
  "version": "1.0.0",
  "description": "Low-level FFI bindings to the PC/SC C API for Node.js",
  "keywords": [
    "ffi",
    "pcsc",
    "smartcard"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/remirth/pcsc"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "koffi": ">=2.14.1"
  },
  "peerDependenciesMeta": {
    "koffi": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
